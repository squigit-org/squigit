{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@squigit/core": ["../core/src/index.ts"],
      "@squigit/core/*": ["../core/src/*"],
      "react": ["../../../renderer/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../../../renderer/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react-dom": [
        "../../../renderer/node_modules/@types/react-dom/index.d.ts"
      ],
      "react-dom/client": [
        "../../../renderer/node_modules/@types/react-dom/client.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "react": ["../desktop/renderer/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../desktop/renderer/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react-dom": [
        "../desktop/renderer/node_modules/@types/react-dom/index.d.ts"
      ],
      "react-dom/client": [
        "../desktop/renderer/node_modules/@types/react-dom/client.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
